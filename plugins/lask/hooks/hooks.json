{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/director-context.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Agent|Task)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/tier-agent.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^Workflow$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/tier-workflow.js\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^(Edit|Write|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/director-enforce.js\" \"${CLAUDE_PLUGIN_DATA}\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
